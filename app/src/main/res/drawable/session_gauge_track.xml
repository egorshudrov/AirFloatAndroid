<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#AA0C0F12" />
            <stroke
                android:width="1dp"
                android:color="#2EFFFFFF" />
        </shape>
    </item>
    <item
        android:left="12dp"
        android:top="10dp"
        android:right="12dp"
        android:bottom="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF1D9E75"
                android:centerColor="#FFEF9F27"
                android:endColor="#FFFF6A5A" />
        </shape>
    </item>
</layer-list>
