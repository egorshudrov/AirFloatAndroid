<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#24000000">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="90"
                android:startColor="@color/acid_lime_400"
                android:centerColor="#F0F75A"
                android:endColor="#D8EC43" />
            <stroke
                android:width="1dp"
                android:color="@color/acid_lime_border" />
        </shape>
    </item>
</ripple>
