<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="34dp" />
            <gradient
                android:angle="90"
                android:startColor="#D90A0A0B"
                android:centerColor="#E60F1114"
                android:endColor="#D90A0A0B" />
            <stroke
                android:width="1dp"
                android:color="#0FFFFFFF" />
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="33dp" />
            <gradient
                android:angle="270"
                android:startColor="#10FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
