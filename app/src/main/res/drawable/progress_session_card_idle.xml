<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="315"
                android:startColor="#14FFFFFF"
                android:centerColor="#09FFFFFF"
                android:endColor="#140A0A0B" />
            <stroke
                android:width="1dp"
                android:color="#18FFFFFF" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <gradient
                android:angle="270"
                android:startColor="#12FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
