<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:angle="90"
                android:startColor="#F5F0E7DD"
                android:centerColor="#D5D1C6B7"
                android:endColor="#EFE7D6C1" />
            <stroke
                android:width="1dp"
                android:color="#99FFFFFF" />
        </shape>
    </item>
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#6E171C20" />
        </shape>
    </item>
</layer-list>
