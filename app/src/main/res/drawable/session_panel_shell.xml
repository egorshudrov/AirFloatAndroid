<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="90"
                android:startColor="#E20E1013"
                android:centerColor="#EF14191D"
                android:endColor="#D1110E0C" />
            <stroke
                android:width="1dp"
                android:color="#2EFFFFFF" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <gradient
                android:angle="270"
                android:startColor="#24FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
