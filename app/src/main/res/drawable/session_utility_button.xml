<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#140A0A0B">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="90"
                android:startColor="#CC0F1215"
                android:centerColor="#D715191D"
                android:endColor="#BF100D0B" />
            <stroke
                android:width="1dp"
                android:color="#36FFFFFF" />
        </shape>
    </item>
</ripple>
