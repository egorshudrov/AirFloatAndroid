<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="315"
                android:startColor="#14FFFFFF"
                android:centerColor="#0E15171B"
                android:endColor="#FF0C0D0F" />
            <stroke
                android:width="1dp"
                android:color="@color/surface_border_8" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="21dp" />
            <gradient
                android:angle="270"
                android:startColor="#16FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item android:right="-28dp" android:top="-20dp" android:left="110dp" android:bottom="120dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="160dp"
                android:startColor="#18E8FF47"
                android:centerColor="#08E8FF47"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
