<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:startColor="#FF101113"
                android:centerColor="#FF13161A"
                android:endColor="#FF090A0B" />
            <stroke
                android:width="1dp"
                android:color="#40E8FF47" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <gradient
                android:angle="270"
                android:startColor="#18FFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#28E8FF47" />
        </shape>
    </item>
</layer-list>
