<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="34dp" />
            <gradient
                android:angle="90"
                android:startColor="#DE101418"
                android:centerColor="#C915181C"
                android:endColor="#E61B140F" />
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="33dp" />
            <gradient
                android:angle="270"
                android:startColor="#24FFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="34dp" />
            <stroke
                android:width="1dp"
                android:color="#4DFFFFFF" />
        </shape>
    </item>
    <item android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#1FC9C0B3" />
        </shape>
    </item>
</layer-list>
