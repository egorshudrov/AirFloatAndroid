<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="38dp" />
            <gradient
                android:angle="90"
                android:startColor="#F00D1013"
                android:centerColor="#F315191D"
                android:endColor="#EA17110E" />
            <stroke
                android:width="1dp"
                android:color="#42FFFFFF" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <gradient
                android:angle="270"
                android:startColor="#2EFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
