<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="315"
                android:startColor="#20FFFFFF"
                android:centerColor="#101A1D21"
                android:endColor="#18090A0B" />
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <gradient
                android:angle="270"
                android:startColor="#1BFFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#10FFFFFF" />
        </shape>
    </item>
</layer-list>
