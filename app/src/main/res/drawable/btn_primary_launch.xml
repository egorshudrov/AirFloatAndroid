<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#24FFFFFF">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="90"
                android:startColor="#FFE3B57B"
                android:centerColor="#FFD59B55"
                android:endColor="#FFC78644" />
            <stroke
                android:width="1dp"
                android:color="#FFF7E8D2" />
            <padding
                android:left="18dp"
                android:top="16dp"
                android:right="18dp"
                android:bottom="16dp" />
        </shape>
    </item>
</ripple>
