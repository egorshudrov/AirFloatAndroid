<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:startColor="#1D1A1D21"
                android:centerColor="#19111316"
                android:endColor="#EE0A0A0B" />
            <stroke
                android:width="1dp"
                android:color="#28FFFFFF" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <gradient
                android:angle="270"
                android:startColor="#18FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
