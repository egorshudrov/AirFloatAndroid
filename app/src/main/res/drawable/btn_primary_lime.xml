<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#24000000">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="@color/acid_lime_400" />
            <stroke
                android:width="1dp"
                android:color="@color/acid_lime_border" />
            <padding
                android:left="18dp"
                android:top="16dp"
                android:right="18dp"
                android:bottom="16dp" />
        </shape>
    </item>
</ripple>
