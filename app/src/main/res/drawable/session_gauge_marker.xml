<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="90"
                android:startColor="#FFF7F3EA"
                android:centerColor="#FFE5D7BF"
                android:endColor="#FFF5EAD8" />
            <stroke
                android:width="1dp"
                android:color="#96FFFFFF" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#7C11161A" />
        </shape>
    </item>
</layer-list>
