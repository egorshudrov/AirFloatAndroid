<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="315"
                android:startColor="#1CFFFFFF"
                android:centerColor="#101A1D21"
                android:endColor="#160A0A0B" />
            <stroke
                android:width="1dp"
                android:color="#4A1D9E75" />
        </shape>
    </item>
    <item android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <gradient
                android:angle="270"
                android:endColor="#0D1D9E75"
                android:startColor="#24FFFFFF" />
        </shape>
    </item>
</layer-list>
