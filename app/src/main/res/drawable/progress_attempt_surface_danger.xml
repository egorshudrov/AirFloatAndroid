<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="315"
                android:startColor="#18B34848"
                android:centerColor="#100F1415"
                android:endColor="#1808090A" />
            <stroke
                android:width="1dp"
                android:color="#36FF4D4D" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="19dp" />
            <gradient
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item android:left="138dp" android:top="-26dp" android:right="-18dp" android:bottom="120dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="170dp"
                android:startColor="#18FF4D4D"
                android:centerColor="#08FF4D4D"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
