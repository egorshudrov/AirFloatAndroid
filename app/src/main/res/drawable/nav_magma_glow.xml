<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="0"
                android:startColor="#A34A1700"
                android:centerColor="#CCB44910"
                android:endColor="#A3E3F15B" />
            <stroke
                android:width="1dp"
                android:color="#24FFF2B6" />
        </shape>
    </item>

    <item android:left="12dp" android:top="10dp" android:right="12dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="270"
                android:startColor="#28FFF7C6"
                android:centerColor="#12FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
