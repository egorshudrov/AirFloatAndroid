<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="315"
                android:startColor="#FF0C0D10"
                android:centerColor="#FF121711"
                android:endColor="#FF090A0B" />
            <stroke
                android:width="1dp"
                android:color="@color/surface_border_12" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <gradient
                android:angle="270"
                android:startColor="#20FFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#16FFFFFF" />
        </shape>
    </item>
</layer-list>
