<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:startColor="#FF0E1012"
                android:centerColor="#FF111419"
                android:endColor="#FF08090A" />
            <stroke
                android:width="1dp"
                android:color="@color/surface_border_8" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <gradient
                android:angle="270"
                android:startColor="#12FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
