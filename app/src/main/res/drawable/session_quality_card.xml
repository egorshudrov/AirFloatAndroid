<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="90"
                android:startColor="#D8111418"
                android:centerColor="#E0151A1F"
                android:endColor="#CB110F0D" />
            <stroke
                android:width="1dp"
                android:color="#30FFFFFF" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <gradient
                android:angle="270"
                android:startColor="#1FFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
