<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/consistency_bottom_sheet_surface"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/consistencySheetTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed"
        android:includeFontPadding="false"
        android:text="REST DAYS"
        android:textAllCaps="true"
        android:textColor="#F0EDE8"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/consistencySheetBodyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:text="Choose which days count as planned rest."
        android:textColor="#444444"
        android:textSize="10sp" />

    <LinearLayout
        android:id="@+id/consistencySheetToggleRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/consistencySheetMon"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/consistency_rest_day_toggle_idle"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="MON"
            android:textAllCaps="true"
            android:textColor="#555555"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/consistencySheetTue"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/consistency_rest_day_toggle_idle"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="TUE"
            android:textAllCaps="true"
            android:textColor="#555555"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/consistencySheetWed"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/consistency_rest_day_toggle_idle"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="WED"
            android:textAllCaps="true"
            android:textColor="#555555"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/consistencySheetThu"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/consistency_rest_day_toggle_idle"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="THU"
            android:textAllCaps="true"
            android:textColor="#555555"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/consistencySheetFri"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/consistency_rest_day_toggle_idle"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="FRI"
            android:textAllCaps="true"
            android:textColor="#555555"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/consistencySheetSat"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/consistency_rest_day_toggle_idle"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="SAT"
            android:textAllCaps="true"
            android:textColor="#555555"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/consistencySheetSun"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/consistency_rest_day_toggle_idle"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="SUN"
            android:textAllCaps="true"
            android:textColor="#555555"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/consistencySheetSaveButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/workout_start_button"
        android:fontFamily="sans-serif-condensed"
        android:gravity="center"
        android:text="SAVE"
        android:textAllCaps="true"
        android:textColor="#0A0A0B"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>
