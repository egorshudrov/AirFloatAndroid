<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/firstLaunchScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_950"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/firstLaunchEyebrowText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:letterSpacing="0.14"
                android:text="FIRST LAUNCH"
                android:textAllCaps="true"
                android:textColor="@color/bone_200"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/firstLaunchStepText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="STEP 1 / 3"
                android:textAllCaps="true"
                android:textColor="@color/hud_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/firstLaunchTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:text="WELCOME TO AIRFLOAT"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_primary"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/firstLaunchBodyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="2dp"
            android:text="AIRFLOAT gives you a clear daily loop: what to train, how to start, how to perform, and what to review next."
            android:textColor="@color/bone_200"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/firstLaunchFeatureCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/consistency_calendar_section_shell"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/firstLaunchFeatureLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="WHY IT WORKS"
                android:textAllCaps="true"
                android:textColor="@color/bone_200"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/firstLaunchFeatureLineOneText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-condensed"
                android:text="Today tells you where to focus."
                android:textColor="@color/hud_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/firstLaunchFeatureLineTwoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="Train launches the session. Live tracks the set. Progress closes the loop."
                android:textColor="@color/hud_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/firstLaunchProgramCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/consistency_calendar_section_shell"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/firstLaunchProgramLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="WEEKLY REST DAYS"
                android:textAllCaps="true"
                android:textColor="@color/bone_200"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/firstLaunchProgramHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:text="Tap the days you usually rest. You can still fine-tune single dates later in Progress."
                android:textColor="@color/hud_text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/firstLaunchMon"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="MON"
                    android:textAllCaps="true"
                    android:textColor="#555555"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/firstLaunchTue"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="TUE"
                    android:textAllCaps="true"
                    android:textColor="#555555"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/firstLaunchWed"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="WED"
                    android:textAllCaps="true"
                    android:textColor="#555555"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/firstLaunchThu"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="THU"
                    android:textAllCaps="true"
                    android:textColor="#555555"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/firstLaunchFri"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="FRI"
                    android:textAllCaps="true"
                    android:textColor="#555555"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/firstLaunchSat"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="SAT"
                    android:textAllCaps="true"
                    android:textColor="#555555"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/firstLaunchSun"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="SUN"
                    android:textAllCaps="true"
                    android:textColor="#555555"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/firstLaunchBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:text="BACK"
                android:textAllCaps="true"
                android:textColor="@color/hud_text_secondary"
                android:textSize="10sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/firstLaunchContinueButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/btn_primary_lime"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:text="NEXT"
                android:textAllCaps="true"
                android:textColor="@color/obsidian_950"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
