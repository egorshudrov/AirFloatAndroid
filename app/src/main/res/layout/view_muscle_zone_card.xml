<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/body_map_zone_card"
    android:minHeight="66dp"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/bodyMapZoneName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-condensed"
            android:text="CHEST"
            android:textAllCaps="true"
            android:textColor="#F0EDE8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bodyMapZoneScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="87"
            android:textColor="#1D9E75"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bodyMapZoneProgressTrack"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="10dp"
        android:background="#1A1A1A">

        <View
            android:id="@+id/bodyMapZoneProgressFill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="#1D9E75" />
    </FrameLayout>

    <TextView
        android:id="@+id/bodyMapZoneLastSeen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="monospace"
        android:text="2D AGO"
        android:textAllCaps="true"
        android:textColor="@color/bone_200"
        android:textSize="9sp" />
</LinearLayout>
