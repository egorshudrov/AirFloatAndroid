<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/body_map_exercise_row"
    android:gravity="center_vertical"
    android:minHeight="50dp"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <View
        android:id="@+id/bodyMapExerciseDot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/body_map_exercise_dot" />

    <TextView
        android:id="@+id/bodyMapExerciseName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:text="Barbell Press"
        android:textColor="#F0EDE8"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/bodyMapExerciseAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:background="@drawable/body_map_exercise_action"
        android:fontFamily="monospace"
        android:paddingStart="8dp"
        android:paddingTop="3dp"
        android:paddingEnd="8dp"
        android:paddingBottom="3dp"
        android:text="OPEN"
        android:textAllCaps="true"
        android:textColor="@color/bone_300"
        android:textSize="9sp"
        android:textStyle="bold" />
</LinearLayout>
