<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/bodyMapTopSplit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/bodyMapPrimaryVisualFrame"
            android:layout_width="160dp"
            android:layout_height="320dp"
            android:layout_marginEnd="14dp">

            <FrameLayout
                android:id="@+id/bodyMapPrimaryVisualClip"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/exercise_visual_clip"
                android:clipToOutline="true"
                android:foreground="@drawable/exercise_visual_outline">

                <com.airfloat.app.ui.BodyMapView
                    android:id="@+id/bodyMapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageView
                    android:id="@+id/bodyMapExercisePreviewImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="false"
                    android:contentDescription="Selected zone exercise preview"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/bodyMapCardsColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <include
                android:id="@+id/bodyMapZoneCardChest"
                layout="@layout/view_muscle_zone_card" />

            <include
                android:id="@+id/bodyMapZoneCardCore"
                layout="@layout/view_muscle_zone_card" />

            <include
                android:id="@+id/bodyMapZoneCardArms"
                layout="@layout/view_muscle_zone_card" />

            <include
                android:id="@+id/bodyMapZoneCardLegs"
                layout="@layout/view_muscle_zone_card" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bodyMapDetailSheet"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:alpha="0">

        <LinearLayout
            android:id="@+id/bodyMapDetailContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/body_map_detail_sheet"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/bodyMapDetailTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed"
                    android:text="CHEST"
                    android:textAllCaps="true"
                    android:textColor="#1D9E75"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/bodyMapDetailBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/body_map_detail_badge"
                    android:fontFamily="monospace"
                    android:paddingStart="8dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="3dp"
                    android:text="SOLID"
                    android:textAllCaps="true"
                    android:textColor="#04342C"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/bodyMapDetailMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:text="2 EXERCISES MAPPED · 48H AGO"
                android:textAllCaps="true"
                android:textColor="@color/bone_200"
                android:textSize="10sp" />

            <LinearLayout
                android:id="@+id/bodyMapExercisesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/bodyMapDetailHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="monospace"
                android:maxLines="2"
                android:text="Diagnostic note lives here."
                android:textColor="@color/bone_200"
                android:textSize="10sp" />

            <Button
                android:id="@+id/bodyMapDetailActionButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/body_map_detail_action"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:text="LAUNCH ZONE"
                android:textAllCaps="true"
                android:textColor="@color/obsidian_950"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
