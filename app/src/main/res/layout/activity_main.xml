<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cyberpunk"
    android:clipChildren="false"
    android:clipToPadding="false">

    <FrameLayout
        android:id="@+id/prestartPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="18dp"
        android:paddingTop="22dp"
        android:paddingEnd="18dp"
        android:paddingBottom="26dp">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/workoutContentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/countdownText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/session_countdown_badge"
            android:fontFamily="sans-serif-condensed"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="0.14"
            android:minWidth="236dp"
            android:paddingStart="28dp"
            android:paddingTop="20dp"
            android:paddingEnd="28dp"
            android:paddingBottom="20dp"
            android:text="Hands Up! 5"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_primary"
            android:textSize="40sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/rootContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/progressContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/firstLaunchContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/rootSwipeSnapshotOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:visibility="gone" />

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <com.airfloat.app.pose.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <View
        android:id="@+id/hudTopScrim"
        android:layout_width="match_parent"
        android:layout_height="216dp"
        android:background="@drawable/session_hud_scrim_top"
        android:visibility="gone" />

    <View
        android:id="@+id/hudBottomScrim"
        android:layout_width="match_parent"
        android:layout_height="294dp"
        android:layout_gravity="bottom"
        android:background="@drawable/session_hud_scrim_bottom"
        android:visibility="gone" />

    <View
        android:id="@+id/liveCleanFlashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#1447FFB2"
        android:visibility="gone" />

    <View
        android:id="@+id/liveMissFlashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#18FF4D4D"
        android:visibility="gone" />

    <View
        android:id="@+id/livePerfectFlashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#1FE8FF47"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/liveHeaderCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="18dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/session_live_card"
        android:elevation="18dp"
        android:gravity="start"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/liveHeaderBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:letterSpacing="0.16"
            android:text="SESSION LIVE"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/liveHeaderTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:letterSpacing="0.08"
            android:text="BARBELL PRESS"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/liveHeaderMetaText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="00:00 • FORM 0 • CLEAN 0 / MISS 0"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/liveFeedbackCard"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="88dp"
        android:elevation="18dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/liveFeedbackText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:letterSpacing="0.08"
            android:maxLines="1"
            android:text="SESSION LIVE"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/liveFeedbackMetaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="2dp"
            android:maxLines="1"
            android:text="Find the first clean rep to establish baseline."
            android:textColor="@color/hud_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/liveScorePanel"
        android:layout_width="116dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/session_quality_card"
        android:elevation="18dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:letterSpacing="0.14"
            android:text="FORM SCORE"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_secondary"
            android:textSize="8sp"
            android:textStyle="bold" />

        <com.airfloat.app.ui.charts.LiveFormScoreRingView
            android:id="@+id/liveScoreRing"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/liveScoreStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:letterSpacing="0.08"
            android:text="CALIBRATING"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_primary"
            android:gravity="center"
            android:maxLines="2"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/liveRepCounterCluster"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="14dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:translationY="82dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/liveRepCounterLabelText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:letterSpacing="0.18"
            android:text="REPS"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/liveRepCounterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="0"
            android:textColor="@color/hud_text_primary"
            android:textSize="96sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/repFlashText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/session_rep_flash_plate"
        android:fontFamily="sans-serif-condensed"
        android:gravity="center"
        android:includeFontPadding="false"
        android:minWidth="216dp"
        android:paddingStart="36dp"
        android:paddingTop="28dp"
        android:paddingEnd="36dp"
        android:paddingBottom="28dp"
        android:text="1"
        android:textColor="@color/hud_text_primary"
        android:textSize="110sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/conditionCard"
        android:layout_width="236dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="172dp"
        android:background="@drawable/session_live_card"
        android:elevation="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <View
            android:id="@+id/conditionDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top"
            android:layout_marginTop="8dp"
            android:background="@drawable/condition_dot" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/activeBanner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false"
                android:letterSpacing="0.08"
                android:text="Get ready"
                android:textColor="@color/hud_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/conditionHintText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:text="Raise both hands to start."
                android:textColor="@color/hud_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/squatShadowCard"
        android:layout_width="188dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/session_quality_card"
        android:elevation="16dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/squatShadowTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.12"
            android:text="FORM AI"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/squatShadowClassText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-condensed"
            android:text="FORM --"
            android:textColor="@color/hud_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/squatShadowConfidenceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:text="BAD -- · CONF --"
            android:textColor="@color/hud_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/repGaugePanel"
        android:layout_width="118dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:background="@drawable/session_panel_shell"
        android:elevation="16dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/repTotalsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:text="0 CLEAN · 0 MISS"
            android:textColor="@color/hud_text_primary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/repGaugeTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:text="RANGE"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_secondary"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/repGaugeTopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:text="100%"
            android:textColor="@color/bone_300"
            android:textSize="9sp" />

        <FrameLayout
            android:id="@+id/repGaugeTrack"
            android:layout_width="28dp"
            android:layout_height="132dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/session_gauge_track">

            <View
                android:id="@+id/repGaugeMarker"
                android:layout_width="28dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom"
                android:background="@drawable/session_gauge_marker" />
        </FrameLayout>

        <TextView
            android:id="@+id/repGaugeBottomText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="0%"
            android:textColor="@color/bone_300"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/repGaugeHintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Progress down -&gt; up"
            android:textColor="@color/hud_text_secondary"
            android:textSize="10sp"
            android:maxLines="2"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/repTablePanel"
        android:layout_width="160dp"
        android:layout_height="212dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="92dp"
        android:background="@drawable/session_panel_shell"
        android:elevation="16dp"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/repTableTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.12"
            android:text="ATTEMPTS"
            android:textAllCaps="true"
            android:textColor="@color/hud_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/repTableScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/repTableRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <Button
        android:id="@+id/benchButton"
        android:layout_width="132dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="108dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/session_utility_button"
        android:fontFamily="sans-serif-medium"
        android:text="Bench 30s"
        android:textAllCaps="false"
        android:textColor="@color/hud_text_primary"
        android:textSize="11sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/skeletonButton"
        android:layout_width="142dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="108dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/session_utility_button"
        android:fontFamily="sans-serif-medium"
        android:text="Skeleton: On"
        android:textAllCaps="false"
        android:textColor="@color/hud_text_primary"
        android:textSize="11sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/finishButton"
        android:layout_width="160dp"
        android:layout_height="54dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/session_finish_button"
        android:fontFamily="sans-serif-condensed"
        android:letterSpacing="0.08"
        android:text="Finish"
        android:textAllCaps="true"
        android:textColor="@color/obsidian_950"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bottom_nav_shell"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:id="@+id/navMagmaGlow"
            android:layout_width="96dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/nav_magma_glow" />

        <LinearLayout
            android:id="@+id/bottomNavButtonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/navHomeButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/nav_tab_idle"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:text="Today"
                android:textAllCaps="true"
                android:textColor="@color/hud_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navWorkoutButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/nav_tab_idle"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:text="Train"
                android:textAllCaps="true"
                android:textColor="@color/hud_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navProgressButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/nav_tab_idle"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:text="Progress"
                android:textAllCaps="true"
                android:textColor="@color/hud_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_cyberpunk"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/successPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/session_success_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="30dp"
            android:paddingEnd="26dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/session_countdown_badge"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.16"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="SESSION LOCKED"
                android:textAllCaps="true"
                android:textColor="@color/frost_300"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/successText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="0.08"
                android:text="12 CLEAN REPS"
                android:textColor="@color/hud_text_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/successMetaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:maxLines="1"
